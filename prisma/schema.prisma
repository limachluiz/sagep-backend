generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  GESTOR
  PROJETISTA
  CONSULTA
}

enum ProjectStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
  CANCELADO
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  REVISAO
  CONCLUIDA
  CANCELADA
}

enum AtaType {
  CFTV
  FIBRA_OPTICA
}

enum FederativeUnit {
  AM
  RO
  RR
  AC
}

enum EstimateStatus {
  RASCUNHO
  FINALIZADA
  CANCELADA
}

enum ProjectStage {
  ESTIMATIVA_PRECO
  AGUARDANDO_NOTA_CREDITO
  DIEX_REQUISITORIO
  AGUARDANDO_NOTA_EMPENHO
  OS_LIBERADA
  SERVICO_EM_EXECUCAO
  ANALISANDO_AS_BUILT
  ATESTAR_NF
  SERVICO_CONCLUIDO
  CANCELADO
}

model User {
  id            String          @id @default(cuid())
  userCode      Int             @unique @default(autoincrement())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(CONSULTA)
  active        Boolean         @default(true)
  ownedProjects Project[]       @relation("ProjectOwner")
  memberships   ProjectMember[]
  assignedTasks Task[]          @relation("TaskAssignee")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Project {
  id                       String          @id @default(cuid())
  projectCode              Int             @unique @default(autoincrement())
  title                    String
  description              String?
  status                   ProjectStatus   @default(PLANEJAMENTO)
  stage                    ProjectStage    @default(ESTIMATIVA_PRECO)
  ownerId                  String
  owner                    User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members                  ProjectMember[]
  diexRequests             DiexRequest[]
  tasks                    Task[]
  estimates                Estimate[]
  serviceOrders            ServiceOrder[]
  startDate                DateTime?
  endDate                  DateTime?
  creditNoteNumber         String?
  creditNoteReceivedAt     DateTime?
  diexNumber               String?
  diexIssuedAt             DateTime?
  commitmentNoteNumber     String?
  commitmentNoteReceivedAt DateTime?
  serviceOrderNumber       String?
  serviceOrderIssuedAt     DateTime?
  executionStartedAt       DateTime?
  asBuiltReceivedAt        DateTime?
  invoiceAttestedAt        DateTime?
  serviceCompletedAt       DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      String?
  user      User     @relation(fields: [userId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Task {
  id          String     @id @default(cuid())
  taskCode    Int        @unique @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(PENDENTE)
  priority    Int        @default(3)
  projectId   String
  assigneeId  String?
  dueDate     DateTime?
  project     Project    @relation(fields: [projectId], references: [id])
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Ata {
  id             String             @id @default(cuid())
  ataCode        Int                @unique @default(autoincrement())
  items          AtaItem[]
  number         String
  type           AtaType
  estimates      Estimate[]
  vendorName     String
  managingAgency String?
  validFrom      DateTime?
  validUntil     DateTime?
  notes          String?
  isActive       Boolean            @default(true)
  coverageGroups AtaCoverageGroup[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model AtaCoverageGroup {
  id          String                @id @default(cuid())
  ataId       String
  items       AtaItem[]
  estimates   Estimate[]
  code        String
  name        String
  description String?
  ata         Ata                   @relation(fields: [ataId], references: [id], onDelete: Cascade)
  localities  AtaCoverageLocality[]
  createdAt   DateTime              @default(now())

  @@unique([ataId, code])
}

model AtaCoverageLocality {
  id              String           @id @default(cuid())
  coverageGroupId String
  cityName        String
  stateUf         FederativeUnit
  coverageGroup   AtaCoverageGroup @relation(fields: [coverageGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())

  @@unique([coverageGroupId, cityName, stateUf])
}

model AtaItem {
  id              String           @id @default(cuid())
  ataItemCode     Int              @unique @default(autoincrement())
  ataId           String
  coverageGroupId String
  referenceCode   String
  description     String
  unit            String
  estimateItems   EstimateItem[]
  unitPrice       Decimal          @db.Decimal(14, 2)
  notes           String?
  isActive        Boolean          @default(true)
  ata             Ata              @relation(fields: [ataId], references: [id], onDelete: Cascade)
  coverageGroup   AtaCoverageGroup @relation(fields: [coverageGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([ataId, coverageGroupId, referenceCode])
}

model Estimate {
  id                  String                @id @default(cuid())
  estimateCode        Int                   @unique @default(autoincrement())
  projectId           String
  ataId               String
  coverageGroupId     String
  omId                String?
  status              EstimateStatus        @default(RASCUNHO)
  omName              String?
  destinationCityName String
  destinationStateUf  FederativeUnit
  notes               String?
  totalAmount         Decimal               @db.Decimal(14, 2)
  project             Project               @relation(fields: [projectId], references: [id], onDelete: Restrict)
  ata                 Ata                   @relation(fields: [ataId], references: [id], onDelete: Restrict)
  coverageGroup       AtaCoverageGroup      @relation(fields: [coverageGroupId], references: [id], onDelete: Restrict)
  om                  MilitaryOrganization? @relation(fields: [omId], references: [id], onDelete: Restrict)
  items               EstimateItem[]
  diexRequests        DiexRequest[]
  serviceOrders       ServiceOrder[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model EstimateItem {
  id                String             @id @default(cuid())
  estimateItemCode  Int                @unique @default(autoincrement())
  estimateId        String
  ataItemId         String
  referenceCode     String
  description       String
  unit              String
  quantity          Decimal            @db.Decimal(14, 2)
  unitPrice         Decimal            @db.Decimal(14, 2)
  subtotal          Decimal            @db.Decimal(14, 2)
  notes             String?
  diexItems         DiexRequestItem[]
  serviceOrderItems ServiceOrderItem[]
  estimate          Estimate           @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  ataItem           AtaItem            @relation(fields: [ataItemId], references: [id], onDelete: Restrict)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([estimateId, ataItemId])
}

model MilitaryOrganization {
  id        String         @id @default(cuid())
  omCode    Int            @unique @default(autoincrement())
  sigla     String         @unique
  name      String
  cityName  String
  stateUf   FederativeUnit
  estimates Estimate[]
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model DiexRequest {
  id                  String            @id @default(cuid())
  diexCode            Int               @unique @default(autoincrement())
  projectId           String
  estimateId          String
  diexNumber          String?
  issuedAt            DateTime?
  issuingOrganization String            @default("4º CTA")
  commandName         String            @default("COMANDO MILITAR DA AMAZÔNIA")
  pregaoNumber        String            @default("04/2025")
  uasg                String            @default("160016")
  supplierName        String
  supplierCnpj        String
  requesterName       String
  requesterRank       String
  requesterRole       String            @default("Requisitante")
  notes               String?
  totalAmount         Decimal           @db.Decimal(14, 2)
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  estimate            Estimate          @relation(fields: [estimateId], references: [id], onDelete: Restrict)
  items               DiexRequestItem[]
  serviceOrders       ServiceOrder[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([estimateId])
}

model DiexRequestItem {
  id                String       @id @default(cuid())
  diexItemCode      Int          @unique @default(autoincrement())
  diexRequestId     String
  estimateItemId    String
  itemCode          String
  description       String
  supplyUnit        String
  quantityRequested Decimal      @db.Decimal(14, 2)
  unitPrice         Decimal      @db.Decimal(14, 2)
  totalPrice        Decimal      @db.Decimal(14, 2)
  notes             String?
  diexRequest       DiexRequest  @relation(fields: [diexRequestId], references: [id], onDelete: Cascade)
  estimateItem      EstimateItem @relation(fields: [estimateItemId], references: [id], onDelete: Restrict)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([diexRequestId, estimateItemId])
}

model ServiceOrder {
  id                   String             @id @default(cuid())
  serviceOrderCode     Int                @unique @default(autoincrement())
  projectId            String
  estimateId           String
  diexRequestId        String?
  serviceOrderNumber   String
  issuedAt             DateTime
  contractorName       String
  contractorCnpj       String
  commitmentNoteNumber String
  requesterName        String
  requesterRank        String
  requesterRole        String             @default("Fiscal do Contrato")
  issuingOrganization  String             @default("4º CTA")
  isEmergency          Boolean           @default(false)
  plannedStartDate     DateTime?
  plannedEndDate       DateTime?
  notes                String?
  totalAmount          Decimal            @db.Decimal(14, 2)
  project              Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  estimate             Estimate           @relation(fields: [estimateId], references: [id], onDelete: Restrict)
  diexRequest          DiexRequest?       @relation(fields: [diexRequestId], references: [id], onDelete: Restrict)
  items                ServiceOrderItem[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([estimateId])
}

model ServiceOrderItem {
  id                   String       @id @default(cuid())
  serviceOrderItemCode Int          @unique @default(autoincrement())
  serviceOrderId       String
  estimateItemId       String
  itemCode             String
  description          String
  supplyUnit           String
  quantityOrdered      Decimal      @db.Decimal(14, 2)
  unitPrice            Decimal      @db.Decimal(14, 2)
  totalPrice           Decimal      @db.Decimal(14, 2)
  notes                String?
  serviceOrder         ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  estimateItem         EstimateItem @relation(fields: [estimateItemId], references: [id], onDelete: Restrict)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([serviceOrderId, estimateItemId])
}
