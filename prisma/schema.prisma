generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  GESTOR
  PROJETISTA
  CONSULTA
}

enum ProjectStatus {
  PLANEJAMENTO
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
  CANCELADO
}

enum TaskStatus {
  PENDENTE
  EM_ANDAMENTO
  REVISAO
  CONCLUIDA
  CANCELADA
}

model User {
  id            String          @id @default(cuid())
  userCode      Int             @unique @default(autoincrement())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(CONSULTA)
  active        Boolean         @default(true)
  ownedProjects Project[]       @relation("ProjectOwner")
  memberships   ProjectMember[]
  assignedTasks Task[]          @relation("TaskAssignee")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Project {
  id          String          @id @default(cuid())
  projectCode Int             @unique @default(autoincrement())
  title       String
  description String?
  status      ProjectStatus   @default(PLANEJAMENTO)
  ownerId     String
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  tasks       Task[]
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      String?
  user      User     @relation(fields: [userId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Task {
  id          String     @id @default(cuid())
  taskCode    Int        @unique @default(autoincrement())
  title       String
  description String?
  status      TaskStatus @default(PENDENTE)
  priority    Int        @default(3)
  projectId   String
  assigneeId  String?
  dueDate     DateTime?
  project     Project    @relation(fields: [projectId], references: [id])
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}